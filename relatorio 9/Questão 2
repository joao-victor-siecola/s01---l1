class Musico
  attr_reader :nome, :instrumento

  def initialize(nome, instrumento)
    @nome = nome
    @instrumento = instrumento
  end

  def tocar_partitura(peca)
    raise NotImplementedError, "Este método deve ser implementado nas subclasses!"
  end
end

class Pianista < Musico
  def tocar_partitura(peca)
    puts "#{@nome} toca #{peca} lindamente ao piano."
  end
end

class Violinista < Musico
  def tocar_partitura(peca)
    puts "#{@nome} interpreta #{peca} com seu violino."
  end
end

class Maestro
  def initialize(musicos)
    @musicos = musicos
  end

  def iniciar_ensaio(peca)
    puts "\n Ensaio da peça: #{peca} "
    @musicos.each { |m| m.tocar_partitura(peca) }
  end

  def mudar_foco(estado)
    @musicos.map { |m| "#{m.nome} agora está #{estado}!" }
  end
end

# MAIN
m1 = Pianista.new("Kousei", "Piano")
m2 = Violinista.new("Kaori", "Violino")
maestro = Maestro.new([m1, m2])

print "Nome da peça para o ensaio: "
peca = gets.chomp

maestro.iniciar_ensaio(peca)
puts "\nMudança de foco:"
puts maestro.mudar_foco("Concentrado")
