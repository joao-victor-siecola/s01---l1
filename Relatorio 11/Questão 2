import java.util.ArrayList;
import java.util.Scanner;

class Cafe {
    protected String nome;
    protected double precoBase;

    public Cafe(String nome, double precoBase) {
        this.nome = nome;
        this.precoBase = precoBase;
    }

    public double calcularPrecoFinal() {
        return precoBase;
    }
}

class CafeGourmet extends Cafe {
    public CafeGourmet(String nome, double precoBase) {
        super(nome, precoBase);
    }

    @Override
    public double calcularPrecoFinal() {
        return precoBase + 5; // bônus aroma
    }
}

class Menu {
    private ArrayList<Cafe> itens = new ArrayList<>();

    public void adicionarCafe(Cafe c) {
        itens.add(c);
    }

    public void listarMenu() {
        System.out.println("\nMENU:");
        for (Cafe c : itens) {
            System.out.println(c.nome + " - R$ " + c.calcularPrecoFinal());
        }
    }
}

class Cafeteria {
    private Menu menu = new Menu();

    public Menu getMenu() {
        return menu;
    }
}

public class CafeMain {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Cafeteria leblanc = new Cafeteria();

        while(true) {
            System.out.print("Nome do café (ENTER para parar): ");
            String nome = sc.nextLine();
            if (nome.isEmpty()) break;

            System.out.print("Preço base: ");
            double preco = sc.nextDouble();
            sc.nextLine();

            System.out.print("É gourmet? (s/n): ");
            String t = sc.nextLine();

            if (t.equalsIgnoreCase("s"))
                leblanc.getMenu().adicionarCafe(new CafeGourmet(nome, preco));
            else
                leblanc.getMenu().adicionarCafe(new Cafe(nome, preco));
        }

        leblanc.getMenu().listarMenu();
        sc.close();
    }
}
