function filtrarPares(tabela)
    local pares = {}
    for i = 1, #tabela do
        if tabela[i] % 2 == 0 then
            table.insert(pares, tabela[i])
        end
    end
    return pares
end

-- Exemplo de uso
local numeros = {1, 2, 3, 4, 5, 6, 8}
local pares = filtrarPares(numeros)

print("Números pares encontrados:")
for i = 1, #pares do
    print(pares[i])
end
