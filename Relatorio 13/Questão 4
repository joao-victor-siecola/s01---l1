(defstruct ocorrencia nome ritual nivel-medo agentes-enviados)

(defun soma-medo-recursiva (lst)
  (if (null lst)
      0
      (+ (ocorrencia-nivel-medo (car lst))
         (soma-medo-recursiva (cdr lst)))))

(defun analise-final (lista)
  (let* ((total (soma-medo-recursiva lista))
         (n (length lista))
         (media (if (> n 0) (/ total n) 0)))
    (remove-if-not
     (lambda (o)
       (and (> (ocorrencia-agentes-enviados o) 3)
            (> (ocorrencia-nivel-medo o) media)))
     lista)))

(defparameter *lista* nil)

(loop
  (format t "~%Nome da ocorrencia (ENTER para finalizar): ")
  (let ((nome (read-line)))
    (if (string= nome "")
        (return)
        (progn
          (format t "Ritual: ")
          (let ((ritual (read-line)))
            (format t "Nivel de medo: ")
            (let ((medo (parse-integer (read-line))))
              (format t "Agentes enviados: ")
              (let ((agentes (parse-integer (read-line))))
                (push (make-ocorrencia :nome nome :ritual ritual :nivel-medo medo :agentes-enviados agentes)
                      *lista*))))))))

(setq *lista* (reverse *lista*))

(format t "~%Ocorrencias criticas: ~a~%"
        (mapcar #'ocorrencia-nome (analise-final *lista*)))

